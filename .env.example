# AWS Configuration (for x86_64 builds on EC2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_INSTANCE_TYPE=t3.medium

# Build Configuration
MARS_ARCH=amd64          # amd64 or arm64
MARS_VARIANT=desktop     # desktop or minimal
MARS_VERSION=0.1.0
MARS_SUITE=trixie        # Debian suite
